{
  "name": "demo-truckerio",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.11.30",
    "typescript": "^5.5.4"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:all": "docker-compose up -d && pnpm dev",
    "prod:local": "docker compose -p prodlocal --env-file .env.prod.local -f infra/docker/docker-compose.prod-local.yml up -d --build",
    "prod:local:down": "docker compose -p prodlocal --env-file .env.prod.local -f infra/docker/docker-compose.prod-local.yml down --remove-orphans",
    "prod:local:bootstrap": "bash scripts/dev/bootstrap-prod-local.sh",
    "prod:local:reset-seed": "bash scripts/dev/reset-and-seed.sh",
    "prod:local:seed:new-features": "bash scripts/dev/seed-demo-new-features.sh",
    "dev:web": "pnpm --filter @truckerio/web dev",
    "dev:api": "pnpm --filter @truckerio/api dev",
    "dev:worker": "pnpm --filter @truckerio/worker dev",
    "build": "pnpm -w prisma:generate",
    "db:migrate": "pnpm --filter @truckerio/db migrate",
    "db:seed": "pnpm --filter @truckerio/db seed",
    "db:studio": "pnpm --filter @truckerio/db studio",
    "demo:up": "bash scripts/demo-up.sh",
    "demo:down": "bash scripts/demo-down.sh",
    "demo:seed": "pnpm --filter @truckerio/api exec tsx scripts/demo-seed.ts",
    "demo:refresh": "pnpm --filter @truckerio/api exec tsx scripts/demo-refresh.ts",
    "demo:reset": "pnpm --filter @truckerio/api exec tsx scripts/demo-reset.ts",
    "demo:populate": "pnpm --filter @truckerio/api exec tsx scripts/demo-populate.ts",
    "demo:seed:ltl": "pnpm --filter @truckerio/api exec tsx scripts/seed-ltl-examples.ts",
    "demo:test:trip": "pnpm --filter @truckerio/api exec tsx scripts/trip-e2e-check.ts",
    "company:reset": "pnpm --filter @truckerio/api exec tsx scripts/company-reset.ts",
    "demo:smoke": "pnpm --filter @truckerio/api exec tsx scripts/smoke-happy-path.ts && pnpm --filter @truckerio/api exec tsx scripts/smoke-failure-paths.ts && pnpm --filter @truckerio/api exec tsx scripts/tenant-isolation.ts",
    "demo:smoke:phase2": "pnpm --filter @truckerio/api exec tsx scripts/smoke-phase2-trip-finance.ts",
    "demo:smoke:phase3": "pnpm --filter @truckerio/api exec tsx scripts/smoke-kernel-first-wave.ts",
    "demo:smoke:phase4": "pnpm --filter @truckerio/api run test:driver && pnpm --filter @truckerio/web run test:driver && pnpm --filter @truckerio/api run test:today && pnpm --filter @truckerio/web run test:today",
    "demo:smoke:phase5": "pnpm --filter @truckerio/api exec node --import tsx scripts/smoke-phase5-finance-chain.ts",
    "demo:smoke:phase7": "pnpm --filter @truckerio/web run test:finance",
    "demo:smoke:enforce": "pnpm --filter @truckerio/api exec tsx scripts/smoke-kernel-enforce-wave.ts",
    "demo:smoke:roles": "pnpm --filter @truckerio/api exec tsx scripts/smoke-role-matrix.ts",
    "demo:kernel:report": "pnpm --filter @truckerio/api exec tsx scripts/kernel-divergence-report.ts",
    "setupcode:create": "pnpm --filter @truckerio/api exec tsx scripts/setupcode-create.ts",
    "prisma:generate": "pnpm --filter @truckerio/db exec prisma generate",
    "qa:setup": "pnpm --filter @truckerio/api exec tsx --tsconfig tsconfig.scripts.json ../../scripts/qa/qa-setup.ts",
    "qa:tests": "pnpm --filter @truckerio/api exec tsx --tsconfig tsconfig.scripts.json ../../scripts/qa/qa-tests.ts",
    "qa:smoke": "pnpm --filter @truckerio/api exec tsx --tsconfig tsconfig.scripts.json ../../scripts/qa/qa-smoke.ts",
    "qa:report": "pnpm --filter @truckerio/api exec tsx --tsconfig tsconfig.scripts.json ../../scripts/qa/qa-report.ts",
    "qa:all": "bash -c 'pnpm qa:setup && pnpm qa:tests && pnpm qa:smoke; pnpm qa:report'",
    "ci:drift:roles": "node scripts/ci/check-role-capability-drift.mjs",
    "ci:drift:status": "node scripts/ci/check-load-status-mutation-drift.mjs",
    "ci:drift": "pnpm ci:drift:roles && pnpm ci:drift:status",
    "ci:kernel:pilot": "pnpm --filter @truckerio/api run test:kernel && pnpm demo:kernel:report",
    "ci:kernel:phase3": "pnpm ci:kernel:pilot && pnpm demo:smoke:phase3",
    "ci:phase4": "pnpm demo:smoke:phase4",
    "ci:phase5": "pnpm --filter @truckerio/api run test:finance && pnpm --filter @truckerio/api exec tsc -p tsconfig.json --noEmit && pnpm demo:smoke:phase5",
    "ci:phase6": "pnpm --filter @truckerio/api run test:finance && pnpm --filter @truckerio/api exec tsc -p tsconfig.json --noEmit && pnpm --filter @truckerio/web run test:finance && pnpm --filter @truckerio/web run typecheck",
    "ci:phase7": "pnpm --filter @truckerio/api run test:finance && pnpm --filter @truckerio/api exec tsc -p tsconfig.json --noEmit && pnpm --filter @truckerio/web run test:finance && pnpm --filter @truckerio/web run typecheck && pnpm demo:smoke:phase7",
    "ci:kernel:phasee": "pnpm ci:kernel:phase3 && pnpm demo:smoke:roles && pnpm demo:smoke:enforce"
  }
}
